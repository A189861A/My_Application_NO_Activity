<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
<!--    填充颜色：如果是透明边框，可以不写或者设置为透明-->
    <solid android:color="#ffffff" />
    <!-- 边框设置 -->
    <!-- width: 边框宽度，1px -->
    <!-- color: 边框颜色 -->
    <stroke
        android:width="1dp"
        android:color="#FF0000" />
    <!-- 圆角设置 -->
    <corners
        android:radius="5dp" />
</shape>